{
  "name": "daovibe_mycelium_engine",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "ts-node src/tests/runUnitTests.ts",
    "dev": "ts-node src/server.ts",
    "demo": "ts-node src/index.ts",
    "app:dev": "vite --config apps/mycelium-web/vite.config.ts",
    "app:build": "vite build --config apps/mycelium-web/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "server": "ts-node src/server.ts",
    "simulate:two-node": "ts-node src/simulations/twoNodeSyncSimulation.ts",
    "simulate:http-two-node": "ts-node src/simulations/httpTwoNodeSyncSimulation.ts",
    "simulate:three-node": "ts-node src/simulations/threeNodeSyncSimulation.ts",
    "simulate:unique-voters": "ts-node src/simulations/uniqueVoterConfidenceSimulation.ts",
    "simulate:sync-batch-size": "ts-node src/simulations/syncBatchSizeGuardSimulation.ts",
    "simulate:sync-cursor-monotonicity": "ts-node src/simulations/syncCursorMonotonicitySimulation.ts",
    "simulate:sync-import-atomicity": "ts-node src/simulations/syncImportAtomicitySimulation.ts",
    "simulate:all": "npm run simulate:two-node && npm run simulate:http-two-node && npm run simulate:three-node && npm run simulate:unique-voters && npm run simulate:sync-batch-size && npm run simulate:sync-cursor-monotonicity && npm run simulate:sync-import-atomicity && npm run simulate:app-api-smoke && npm run simulate:kyc-identity && npm run simulate:payment-intent && npm run simulate:payment-proof",
    "simulate:app-api-smoke": "ts-node src/simulations/appApiSmokeSimulation.ts",
    "app:test": "vitest run --config apps/mycelium-web/vitest.config.ts",
    "simulate:kyc-identity": "ts-node src/simulations/kycIdentityPacketSimulation.ts",
    "simulate:payment-intent": "ts-node src/simulations/paymentIntentPacketSimulation.ts",
    "simulate:payment-proof": "ts-node src/simulations/paymentProofPacketSimulation.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
